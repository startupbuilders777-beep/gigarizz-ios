# =============================================================================
# GigaRizz Backend Configuration
# =============================================================================
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true
ENVIRONMENT=development            # production | staging | development

# ── Database ──────────────────────────────────────────────────────────────────
# Dev:  sqlite+aiosqlite:///./gigarizz.db
# Prod: postgresql+asyncpg://USER:PASS@HOST:5432/gigarizz
DATABASE_URL=sqlite+aiosqlite:///./gigarizz.db

# ── Redis (optional, used for Celery + caching) ───────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AI providers — REQUIRED FOR REAL GENERATION ───────────────────────────────
# OpenAI: GPT Image 1, GPT Image 2, DALL-E 3, Coach (bios/openers)
#   Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY
OPENAI_MODEL=gpt-4o-mini

# Replicate: Flux family, SDXL, SD3, RealVisXL, Playground, Ideogram,
#            InstantID, CodeFormer (face_restore)
#   Get token: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_REPLACE_WITH_YOUR_REPLICATE_TOKEN

# fal.ai: Flux variants, Recraft V3, SDXL Lightning, Nano Banana 2
#   Get key: https://fal.ai/dashboard/keys
FAL_KEY=fal_REPLACE_WITH_YOUR_FAL_KEY

# ── Photo storage — REQUIRED FOR SOURCE-IMAGE UPLOAD ─────────────────────────
# Real S3 (recommended): us-east-1 (or wherever)
# Cloudflare R2: set S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
# MinIO local dev: set S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=gigarizz-photos
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE
AWS_SECRET_ACCESS_KEY=REPLACE
S3_ENDPOINT_URL=

# ── Firebase (optional in dev — production blocks unauthenticated requests) ──
FIREBASE_PROJECT_ID=gigarizz-app
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# ── Content Moderation ────────────────────────────────────────────────────────
MODERATION_ENABLED=true            # Set false to disable OpenAI moderation calls

# ── Webhook (Replicate callbacks) ─────────────────────────────────────────────
WEBHOOK_BASE_URL=                  # e.g. https://api.gigarizz.app
WEBHOOK_SECRET=whsec_REPLACE

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_GENERATION=10/hour
RATE_LIMIT_COACH=30/hour

# =============================================================================
# Feature Flags — edit these to remotely control the iOS app.
# iOS pulls /api/v1/flags on cold start + every 1h. Toggle ANY of these
# (no app update needed) and the iOS UI updates on next refresh.
# =============================================================================

# ── Core surfaces ─────────────────────────────────────────────────────────────
FLAG_ENABLE_GENERATION=true
FLAG_ENABLE_COACH=true
FLAG_ENABLE_FACE_SWAP=false
FLAG_ENABLE_BACKGROUND_REPLACER=true
FLAG_ENABLE_EXPRESSION_COACH=true
FLAG_ENABLE_PHOTO_RANKING=true
FLAG_ENABLE_COLOR_GRADE=true
FLAG_ENABLE_POSE_LIBRARY=true
FLAG_ENABLE_INTRO_OFFER=true
FLAG_ENABLE_BATCH_GENERATION=true

# ── Model tier surfaces ───────────────────────────────────────────────────────
FLAG_ENABLE_PREMIUM_MODELS=true
FLAG_ENABLE_PHOTOREALISTIC_MODELS=true
FLAG_ENABLE_ARTISTIC_MODELS=true

# ── SOTA features (iter 1-9) ──────────────────────────────────────────────────
FLAG_ENABLE_FACE_ENHANCE=true       # Anti-plastic CodeFormer
FLAG_ENABLE_OUTFIT_STUDIO=true      # Nano Banana 2 outfit swap
FLAG_ENABLE_HAIRSTYLE=true          # Nano Banana 2 hair try-on
FLAG_ENABLE_AGE_STUDIO=true         # Nano Banana 2 age slider
FLAG_ENABLE_POSE_STUDIO=true        # InstantID any-pose generator
FLAG_ENABLE_HINGE_OVERLAY=true      # GPT Image 2 prompt-overlay presets
FLAG_ENABLE_NANO_BANANA_2=true      # Show in model picker
FLAG_ENABLE_GPT_IMAGE_2=true        # Show in model picker
FLAG_ENABLE_INSTANT_ID=true         # Show in model picker

# ── Paywall strategy (server-driven A/B) ──────────────────────────────────────
# none = no paywall (everything free, e.g. for App Review demo)
# soft = dismissible paywall after N free uses
# hard = blocking paywall on first launch after onboarding
FLAG_PAYWALL_MODE=soft
FLAG_SOFT_PAYWALL_AFTER_USES=3

# ── Onboarding (server-driven so we can test 5-step vs 30-step) ───────────────
FLAG_ONBOARDING_ENABLED=true
FLAG_ONBOARDING_QUIZ_ENABLED=true
FLAG_ONBOARDING_SKIP_ENABLED=true
FLAG_ONBOARDING_MAX_STEPS=30        # Cap the 30-step luxury flow
FLAG_ONBOARDING_SHOW_SOCIAL_PROOF=true
FLAG_ONBOARDING_SHOW_TESTIMONIALS=true
FLAG_ONBOARDING_SHOW_VIDEO_DEMO=true

# ── Quotas ────────────────────────────────────────────────────────────────────
FLAG_MAX_FREE_GENERATIONS=3
FLAG_MAX_PLUS_GENERATIONS=30
FLAG_MAX_GOLD_GENERATIONS=999
FLAG_MAX_BATCH_MODELS=4

# ── V2 Profile Upgrade flow (Codex V2 plan) ───────────────────────────────────
# When ON, iOS shows the new "Upgrade" tab with audit-first flow and hides the
# legacy ToolsHub tab. Defaults OFF so V1 users are unaffected — flip to true
# for TestFlight cohorts to A/B the V2 shape.
FLAG_ENABLE_V2_UPGRADE_FLOW=false
FLAG_ENABLE_AUDIT_ENDPOINT=true
FLAG_ENABLE_SCREENSHOT_COACH=true

# ── Misc ──────────────────────────────────────────────────────────────────────
FLAG_SHOW_PROMO_BANNER=false
FLAG_MIN_APP_VERSION=1.0.0
