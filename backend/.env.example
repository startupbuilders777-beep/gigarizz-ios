# === GigaRizz Backend Configuration ===

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
ENVIRONMENT=development

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./gigarizz.db

# Redis (for Celery task queue + caching)
REDIS_URL=redis://localhost:6379/0

# OpenAI (for Coach service - bios, openers, prompts)
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY
OPENAI_MODEL=gpt-4o-mini

# Replicate (for photo generation - SDXL/Flux)
REPLICATE_API_TOKEN=r8_REPLACE_WITH_YOUR_REPLICATE_TOKEN

# fal.ai (alternative generation provider)
FAL_KEY=fal_REPLACE_WITH_YOUR_FAL_KEY

# AWS S3 / Cloudflare R2 (photo storage)
S3_BUCKET=gigarizz-photos
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE
AWS_SECRET_ACCESS_KEY=REPLACE
S3_ENDPOINT_URL=  # Leave empty for AWS S3, set for R2/MinIO

# Firebase (auth token verification)
FIREBASE_PROJECT_ID=gigarizz-app
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Content Moderation
MODERATION_ENABLED=true

# Feature Flags defaults
FLAG_ENABLE_GENERATION=true
FLAG_ENABLE_COACH=true
FLAG_ENABLE_FACE_SWAP=false
FLAG_ENABLE_BACKGROUND_REPLACER=true
FLAG_ENABLE_EXPRESSION_COACH=true
FLAG_ENABLE_PHOTO_RANKING=true
FLAG_ENABLE_COLOR_GRADE=true
FLAG_ENABLE_POSE_LIBRARY=true
FLAG_MAX_FREE_GENERATIONS=3
FLAG_MAX_PLUS_GENERATIONS=30
FLAG_MAX_GOLD_GENERATIONS=999
FLAG_SHOW_PROMO_BANNER=false
FLAG_MIN_APP_VERSION=1.0.0

# Rate Limiting
RATE_LIMIT_GENERATION=10/hour
RATE_LIMIT_COACH=30/hour

# Webhook Secret (for Replicate callbacks)
WEBHOOK_SECRET=whsec_REPLACE_WITH_SECRET
