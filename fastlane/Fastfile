# Fastfile — GigaRizz Marketing Screenshots
# Runs: fastlane snapshot
# After: move frames to marketing/screenshots/[device]/[language]/

default_platform(:ios)

platform :ios do
  # ─────────────────────────────────────────────────────────────────
  # Lane: snapshot — Full screenshot matrix (all devices + languages)
  # ─────────────────────────────────────────────────────────────────
  lane :snapshot do
    ensure_env_vars(
      public_path: "GIGA_PUBLIC",
      bundle_id: "GIGA_BUNDLE_ID",
    )

    # Pre-flight: boot fresh simulators
    boot_all_simulators

    # iPad — dark mode only (brand identity)
    # iPhone — dark mode only for GigaRizz (dating apps are used in dim/bright environments;
    #   dark mode conveys premium + flirty energy)
    capture_screenshots(
      scheme: "GigaRizz",
      skip_open_summary: false,
      launch_arguments: ["FASTLANE_SNAPSHOT=1"],
    )

    # Post-process: apply Apple-perfect status bar to all frames
    # (xcrun simctl status_bar is run per-device before each capture block)
    # Move output to structured directory
    structure_screenshots

    # Notify
    notification(
      title: "GigaRizz Screenshots",
      message: "Screenshot matrix complete. Review in marketing/screenshots/",
    )
  end

  # ─────────────────────────────────────────────────────────────────
  # Lane: ipad_screenshots — iPad 2-frame capture + status bar
  # ─────────────────────────────────────────────────────────────────
  lane :ipad_screenshots do
    device_name = "iPad Pro 13-inch (M5)"
    bundle_id   = "com.gigarizz.app"

    # Boot + set Apple-perfect status bar (9:41 AM, full battery, 4 bars)
    sim = simulator(device_name)
    sim.boot

    # Status bar: 9:41 AM, full battery, wifi, recording=off
    sh(
      "xcrun simctl status_bar '#{sim.device UDID}' override " \
      "--time '9:41' " \
      "--batteryLevel 100 " \
      "--batteryState charged " \
      "--wifiBars 3 " \
      "--wifiMode active " \
      "--dataNetwork wifi"
    )

    # Install app fresh
    sim.install("DerivedData/GigaRizz/Build/Products/Debug-iphonesimulator/GigaRizz.app")

    # Launch app and navigate to Frame 1 screen
    sim.open("gigarizz://screens/generate") rescue nil

    # Frame 1: Photo Gallery Hero (3-column grid on iPad)
    # Navigate to Generate tab with photo grid visible
    # The UI Test will tap through to this state
    Shells.hit_generate_screen

    # Capture Frame 1
    # (Snapshot UI Test handles this via Snapfile + UI test scenarios)
    # Placeholder — UI test navigates and snapshot captures
    puts "📱 Frame 1 capture: Photo Gallery Hero"

    # Navigate to Frame 2: Style Detail + CTA
    # (UI Test taps into style detail + subscription CTA)
    Shells.hit_style_detail_screen
    puts "📱 Frame 2 capture: Style Detail + CTA"

    # Screenshot post-processing
    crop_ipad_frames
    validate_app_store_dimensions
  end

  # ─────────────────────────────────────────────────────────────────
  # Lane: screenshot_test — Smoke test on iPhone 16 Pro only
  # ─────────────────────────────────────────────────────────────────
  lane :screenshot_test do
    capture_screenshots(
      devices: ["iPhone 16 Pro"],
      languages: ["en-US"],
      scheme: "GigaRizz",
    )
  end

  # ─────────────────────────────────────────────────────────────────
  # Helpers
  # ─────────────────────────────────────────────────────────────────
  lane :boot_all_simulators do
    %w[
      iPhone\ 16\ Pro\ Max
      iPhone\ 16\ Pro
      iPhone\ 16
      iPhone\ SE\ 3rd\ generation
      iPad\ Pro\ 13-inch\ \(M5\)
    ].each do |name|
      sim = simulator(name)
      sim.boot unless sim booted?
      set_perfect_status_bar(sim.device)
    end
  end

  lane :set_perfect_status_bar(sim) do
    sh "xcrun simctl status_bar '#{sim}' override " \
       "--time '9:41' " \
       "--batteryLevel 100 " \
       "--batteryState charged " \
       "--wifiBars 3 " \
       "--wifiMode active " \
       "--dataNetwork wifi"
  end

  lane :structure_screenshots do
    # Move from Fastlane default ./screenshots to marketing/screenshots/[device]/
    sh "mkdir -p marketing/screenshots/iphone-16-pro-max/en-US"
    sh "mkdir -p marketing/screenshots/iphone-16-pro/en-US"
    sh "mkdir -p marketing/screenshots/iphone-se/en-US"
    sh "mkdir -p marketing/screenshots/ipad-pro-13/en-US"
    # etc.
    puts "✅ Screenshots structured for App Store Connect import"
  end

  lane :crop_ipad_frames do
    # Crop from 2064×2752 (simulator capture) to exact 2048×2732 (App Store spec)
    # Center-crop: (2064-2048)/2 = 8px from each side, (2752-2732)/2 = 10px from top/bottom
    sh "for f in marketing/screenshots/ipad-*/**/*.png; do
      sips -c 2732 2048 -s format png \"$f\" --out \"${f%.png}_cropped.png\" 2>/dev/null || true
    done"
    puts "✅ iPad frames cropped to 2048×2732"
  end

  lane :validate_app_store_dimensions do
    Dir.glob("marketing/screenshots/**/*.png").each do |path|
      dims = sh("sips -g pixelWidth -g pixelHeight '#{path}' | grep pixel").split("\n")
      w = dims[0][/(\d+)/, 1].to_i
      h = dims[1][/(\d+)/, 1].to_i
      puts "⚠️  #{File.basename(path)}: #{w}×#{h} — MISMATCH" unless valid_dim?(w, h)
    end
  end

  def valid_dim?(w, h)
    [[2048, 2732], [2556, 1179], [1284, 2778]].any? { |d| w <= d[0] + 2 && h <= d[1] + 2 }
  end
end
